                            if p:IsA("BodyPosition") or p:IsA("BodyGyro") or p:IsA("BodyVelocity") or p:IsA("BodyForce") then
                                pcall(function() p:Destroy() end)
                            end
                        end
                    end
                end
                local tHum = tChar:FindFirstChildOfClass("Humanoid")
                if tHum then
                    pcall(function()
                        tHum.PlatformStand = false
                        tHum.Sit = false
                    end)
                end
            end
        end
    end)
end

