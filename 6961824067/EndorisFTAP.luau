miscConfigSec:Button({Text = "Import Config", Callback = function()
    warn("[CFG] Import start")
    local raw
    local ok0, err0 = pcall(function() raw = readfile("config.txt") end)
    warn("[CFG] readfile: " .. tostring(ok0) .. " len=" .. tostring(raw and #raw or "nil"))
    if not raw or raw == "" then warn("[CFG] file empty") return end
    warn("[CFG] file start: " .. raw:sub(1, 100))
    local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
    warn("[CFG] JSONDecode: " .. tostring(ok))
    if not ok or type(data) ~= "table" then warn("[CFG] decode err: " .. tostring(data)) return end
    local setterCount = 0
    local flagCount = 0
    for flag, val in pairs(data) do
        if flag ~= "__keybinds__" then
            if library._flagSetters and library._flagSetters[flag] then
                if type(val) == "table" then
                    local current = library.Flags[flag]
                    if type(current) == "table" then
                        for k, v in pairs(val) do
                            current[k] = v
                        end
                    else
                        library.Flags[flag] = val
                    end
                    pcall(function() library._flagSetters[flag](library.Flags[flag]) end)
                    warn("[CFG] setter " .. flag .. "=table ok")
                    setterCount = setterCount + 1
                else
                    local current = library.Flags[flag]
                    if current ~= val then
                        local sOk, sErr = pcall(function() library._flagSetters[flag](val) end)
                        warn("[CFG] setter " .. flag .. "=" .. tostring(val) .. " ok=" .. tostring(sOk) .. " " .. tostring(sErr))
                        setterCount = setterCount + 1
                    end
                end
            elseif string.find(flag, "%.") then
                local section, key = flag:match("^(.-)%.(.+)$")
                if section and key and Settings[section] and Settings[section][key] ~= val then
                    Settings[section][key] = val
                end
            else
                if library.Flags[flag] ~= val then
                    library.Flags[flag] = val
                    flagCount = flagCount + 1
                end
            end
        end
    end
    if data["__keybinds__"] then
        do
            local kbMap = {ZoomBind="Zoom",PalletGodKey="Part Object Grab",PvpSafe="PVP SAFE",PushKey="Push Key",SpamDanceKey="Spam Dance",LegitAimKey="Legit Aim Key",PlayerFlyKey="Fly Key",PlayerClickTPKey="TP Key"}
            local gui = library.ScreenGui
            if gui then
                for fl, kn in pairs(data["__keybinds__"]) do
                    local dn = kbMap[fl]
                    if dn then
                        for _, d in ipairs(gui:GetDescendants()) do
                            if d.Name=="KeybindText" and d:IsA("TextLabel") and d.Text==dn then
                                local p = d.Parent
                                if p and p.Name=="Keybind" then
                                    local f = p:FindFirstChild("KeybindFrame")
                                    if f then
                                        local btn = f:FindFirstChild("KeybindButton")
                                        if btn then
                                            pcall(function() firesignal(btn.MouseButton1Click) end)
                                            task.wait(0.3)
                                            pcall(function()
                                                if kn ~= "" then
                                                    game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode[kn], false, game.Players.LocalPlayer)
                                                else
                                                    game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.Escape, false, game.Players.LocalPlayer)
                                                end
                                            end)
                                            task.wait(0.3)
                                        end
                                    end
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
        warn("[CFG] keybinds loaded")
    end
    warn("[CFG] Done. Setters: " .. setterCount .. " Flags: " .. flagCount)
end})




local function updatePvPCharacter(NewCharacter)
    if not (NewCharacter and NewCharacter:IsDescendantOf(workspace)) then return end
    State.Root = NewCharacter:WaitForChild("HumanoidRootPart", 3)
    if not State.Root then return end
    State.HRPs[State.Root] = nil
end

