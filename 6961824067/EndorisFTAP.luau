function Utility.waitForChild(parent, childName, timeout)
    local startTime = tick()
    while tick() - startTime < (timeout or 5) do
        local child = parent:FindFirstChild(childName)
        if child then return child end
        task.wait(0.1)
    end
    return nil
end

